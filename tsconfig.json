{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"strict": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"declaration": true,
		"declarationMap": true,
		"ignoreDeprecations": "6.0"
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
